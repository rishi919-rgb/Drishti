PORT=3001

# Enable this switch (true) to test the UI without consuming Gemini API tokens
USE_MOCK_AI=false

# Google Gemini API Keys. Provide up to 5 keys to route requests effectively and avoid exhaustion
GEMINI_API_KEY_1=your_first_gemini_api_key
GEMINI_API_KEY_2=your_second_gemini_api_key
GEMINI_API_KEY_3=your_third_gemini_api_key
GEMINI_API_KEY_4=your_fourth_gemini_api_key
GEMINI_API_KEY_5=your_fifth_gemini_api_key

# Optional APIs (If modifying AI providers later)
# GROQ_API_KEY=your_groq_api_key
# DEEPSEEK_API_KEY=your_deepseek_api_key
